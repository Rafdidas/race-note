{
  "name": "race-note",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "test": "tsx --test src/lib/*.test.ts",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "cf:build": "opennextjs-cloudflare build",
    "cf:preview": "opennextjs-cloudflare preview",
    "cf:deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "cf:types": "wrangler types --include-runtime false",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply DB --local --config wrangler.local.jsonc",
    "db:seed:local": "wrangler d1 execute DB --local --config wrangler.local.jsonc --file drizzle/seed.sql",
    "db:migrate:remote": "wrangler d1 migrations apply DB --remote",
    "db:seed:remote": "wrangler d1 execute DB --remote --file drizzle/seed.sql"
  },
  "dependencies": {
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "drizzle-orm": "^0.45.2",
    "next": "16.2.9",
    "pretendard": "^1.3.9",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260612.1",
    "@emnapi/core": "^1.11.0",
    "@emnapi/runtime": "^1.11.0",
    "@opennextjs/cloudflare": "^1.19.11",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "sass": "^1.100.0",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "wrangler": "^4.100.0"
  }
}
